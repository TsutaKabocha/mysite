---
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "月ごとの日記をまとめて記録するサイトです。",
  noindex = false,
} = Astro.props;
const siteName = "Tsuta Kabocha";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;

const pathname = Astro.url.pathname;
const isTop = pathname === "/";
const isDiary = pathname.startsWith("/diary/");

const diaryEntries = await getCollection("diary");
const latestDiaryEntry = [...diaryEntries].sort((a, b) =>
  b.data.yearMonth.localeCompare(a.data.yearMonth)
)[0];
const diaryHref = latestDiaryEntry ? `/diary/${latestDiaryEntry.id}/` : "/";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        var STORAGE_KEY = "theme";
        var stored = localStorage.getItem(STORAGE_KEY);
        var theme =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="ncom-l-container site-header__inner">
        <a href="/" class="site-header__logo">{siteName}</a>
        <nav class="site-header__nav">
          <a href="/" aria-current={isTop ? "page" : undefined}>TOP</a>
          <a href={diaryHref} aria-current={isDiary ? "page" : undefined}
            >DIARY</a
          >
          <button
            type="button"
            id="theme-toggle"
            class="theme-toggle theme-toggle-btn"
            aria-label="ライト/ダークモード切り替え"
          >
            DARK
          </button>
        </nav>
      </div>
    </header>

    <button
      type="button"
      id="hamburger-btn"
      class="hamburger-btn"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="hamburger-btn__line"></span>
      <span class="hamburger-btn__line"></span>
      <span class="hamburger-btn__line"></span>
    </button>

    <div class="nav-drawer-overlay" id="nav-drawer-overlay" hidden></div>
    <nav class="nav-drawer" id="nav-drawer" aria-label="メニュー" aria-hidden="true">
      <ul class="nav-drawer__list">
        <li>
          <a
            href="/"
            class="nav-drawer__link"
            aria-current={isTop ? "page" : undefined}
          >
            TOP
          </a>
        </li>
        <li>
          <a
            href={diaryHref}
            class="nav-drawer__link"
            aria-current={isDiary ? "page" : undefined}
          >
            DIARY
          </a>
        </li>
        <li>
          <button
            type="button"
            id="drawer-theme-toggle"
            class="nav-drawer__link theme-toggle-btn"
            aria-label="ライト/ダークモード切り替え"
          >
            DARK
          </button>
        </li>
      </ul>
    </nav>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="ncom-l-container">
        <p class="site-footer__copy">&copy; 2026 {siteName}</p>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        height: var(--ncom-header-height);
        background-color: var(--ncom-bg-page);
        border-bottom: 1px solid var(--ncom-color-gray-300);
        transition: background-color 0.3s ease, color 0.3s ease,
          transform 0.3s ease, opacity 0.3s ease;
      }

      .site-header.is-hidden {
        transform: translateY(-100%);
        opacity: 0;
        pointer-events: none;
      }

      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
      }

      .site-header__logo {
        color: var(--ncom-color-heading);
        font-family: var(--ncom-ff-ja);
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 0.03em;
      }

      .site-header__nav {
        display: flex;
        gap: 24px;
      }

      .site-header__nav a {
        color: var(--ncom-color-txt);
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
      }

      .site-header__nav a[aria-current="page"] {
        color: var(--color-primary-dark);
      }

      [data-theme="dark"] .site-header__nav a {
        color: var(--color-text);
      }

      [data-theme="dark"] .site-header__nav a[aria-current="page"] {
        color: var(--color-primary-bright);
      }

      [data-theme="dark"] .site-header__nav a:hover {
        color: var(--color-primary-bright);
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        padding: 0;
        border: none;
        background: transparent;
        color: var(--ncom-color-txt);
        font-size: 14px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        transition: color 0.15s ease;
      }

      .theme-toggle:hover {
        color: var(--color-primary-dark);
      }

      [data-theme="dark"] .theme-toggle:hover {
        color: var(--color-primary-bright);
      }

      .hamburger-btn {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 4px;
        background: none;
        cursor: pointer;
        opacity: 0;
        transform: scale(0.85);
        pointer-events: none;
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .hamburger-btn.is-visible {
        opacity: 1;
        transform: scale(1);
        pointer-events: auto;
      }

      .hamburger-btn__line {
        display: block;
        width: 22px;
        height: 2px;
        background-color: var(--color-primary-dark);
        transition: transform 0.25s ease, opacity 0.25s ease,
          background-color 0.3s ease;
      }

      [data-theme="dark"] .hamburger-btn__line {
        background-color: var(--color-primary-bright);
      }

      .hamburger-btn[aria-expanded="true"] .hamburger-btn__line:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
      }

      .hamburger-btn[aria-expanded="true"] .hamburger-btn__line:nth-child(2) {
        opacity: 0;
      }

      .hamburger-btn[aria-expanded="true"] .hamburger-btn__line:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
      }

      .nav-drawer-overlay {
        position: fixed;
        inset: 0;
        z-index: 1001;
        background: rgba(0, 0, 0, 0.3);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
      }

      .nav-drawer-overlay.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .nav-drawer {
        position: fixed;
        top: 56px;
        right: 16px;
        z-index: 1002;
        display: flex;
        flex-direction: column;
        min-width: 140px;
        padding: 8px;
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
        opacity: 0;
        transform: translateY(-8px);
        pointer-events: none;
        transition: opacity 0.2s ease, transform 0.2s ease,
          background-color 0.3s ease;
      }

      .nav-drawer.is-open {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .nav-drawer__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .nav-drawer__link {
        display: block;
        width: 100%;
        padding: 14px 12px;
        border: none;
        border-radius: 4px;
        background: transparent;
        color: var(--ncom-color-heading);
        font-family: var(--ncom-ff-ja);
        font-size: 16px;
        font-weight: 700;
        text-align: left;
        text-decoration: none;
        cursor: pointer;
        transition: background-color 0.15s ease, color 0.15s ease;
      }

      .nav-drawer__link:hover {
        background-color: var(--ncom-bg-surface-100);
        opacity: 1;
      }

      .nav-drawer__link[aria-current="page"] {
        color: var(--color-primary-dark);
      }

      [data-theme="dark"] .nav-drawer__link[aria-current="page"] {
        color: var(--color-primary-bright);
      }

      .site-main {
        min-height: calc(100vh - var(--ncom-header-height) - 80px);
      }

      .site-footer {
        background-color: var(--ncom-bg-footer);
        padding: 32px 0;
        margin-top: 64px;
      }

      .site-footer__copy {
        margin: 0;
        color: var(--ncom-color-txt-sub);
        font-family: var(--ncom-ff-roboto);
        font-size: 13px;
      }
    </style>

    <script>
      // ClientRouter(View Transitions)導入後は、同一の<script>がページ遷移のたびに
      // 再実行されるとは限らず、また遷移でdocument.body配下の要素は丸ごと
      // 差し替えられる(参照を保持していると古いDOMを掴んだままになる)。
      // そのため要素への参照は都度取得し直し、クリック等はdocumentへの
      // イベント委任で受け止めることで、遷移後の新しいDOMにも自然に追従させる。

      const STORAGE_KEY = "theme";

      function currentTheme(): "light" | "dark" {
        return document.documentElement.getAttribute("data-theme") === "dark"
          ? "dark"
          : "light";
      }

      function updateToggleLabels() {
        const label = currentTheme() === "dark" ? "LIGHT" : "DARK";
        document
          .querySelectorAll<HTMLButtonElement>(".theme-toggle-btn")
          .forEach((btn) => {
            btn.textContent = label;
          });
      }

      function toggleTheme() {
        const next = currentTheme() === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem(STORAGE_KEY, next);
        updateToggleLabels();
      }

      updateToggleLabels();
      document.addEventListener("astro:page-load", updateToggleLabels);

      // --- ページ最上部でのみヘッダーを表示し、それ以外はハンバーガーボタンに切り替える ---
      const SCROLL_TOP_THRESHOLD = 10;
      let headerHidden = false;
      let scrollTicking = false;

      function updateHeaderVisibility() {
        scrollTicking = false;
        const header = document.getElementById("site-header");
        const hamburgerBtn = document.getElementById("hamburger-btn");
        if (!header || !hamburgerBtn) return;

        const atTop = window.scrollY < SCROLL_TOP_THRESHOLD;

        if (!atTop && !headerHidden) {
          headerHidden = true;
          header.classList.add("is-hidden");
          hamburgerBtn.classList.add("is-visible");
        } else if (atTop && headerHidden) {
          headerHidden = false;
          header.classList.remove("is-hidden");
          hamburgerBtn.classList.remove("is-visible");
        }
      }

      window.addEventListener(
        "scroll",
        () => {
          if (!scrollTicking) {
            scrollTicking = true;
            requestAnimationFrame(updateHeaderVisibility);
          }
        },
        { passive: true }
      );

      // 遷移直後は新しいページの先頭から見せたいので、ヘッダーの表示状態をリセットする
      document.addEventListener("astro:page-load", () => {
        headerHidden = false;
        document.getElementById("site-header")?.classList.remove("is-hidden");
        document
          .getElementById("hamburger-btn")
          ?.classList.remove("is-visible");
      });

      // --- ドロワーメニュー ---
      let drawerIsOpen = false;

      function openDrawer() {
        const drawer = document.getElementById("nav-drawer");
        const overlay = document.getElementById("nav-drawer-overlay");
        const hamburgerBtn = document.getElementById("hamburger-btn");
        if (!drawer || !overlay || !hamburgerBtn) return;
        drawerIsOpen = true;
        overlay.hidden = false;
        void overlay.offsetHeight; // reflowを強制してtransitionを確実に発火させる
        drawer.classList.add("is-open");
        overlay.classList.add("is-open");
        drawer.setAttribute("aria-hidden", "false");
        hamburgerBtn.setAttribute("aria-expanded", "true");
      }

      function closeDrawer() {
        if (!drawerIsOpen) return;
        drawerIsOpen = false;
        const drawer = document.getElementById("nav-drawer");
        const overlay = document.getElementById("nav-drawer-overlay");
        const hamburgerBtn = document.getElementById("hamburger-btn");
        drawer?.classList.remove("is-open");
        overlay?.classList.remove("is-open");
        drawer?.setAttribute("aria-hidden", "true");
        hamburgerBtn?.setAttribute("aria-expanded", "false");
        window.setTimeout(() => {
          if (!drawerIsOpen && overlay) overlay.hidden = true;
        }, 200);
      }

      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement | null;
        if (!target) return;

        if (target.closest("#hamburger-btn")) {
          drawerIsOpen ? closeDrawer() : openDrawer();
          return;
        }
        if (target.id === "nav-drawer-overlay") {
          closeDrawer();
          return;
        }
        if (target.closest(".theme-toggle-btn")) {
          toggleTheme();
          return;
        }
        // ドロワー内のリンクをクリックした場合(=遷移する場合)は閉じておく
        if (drawerIsOpen && target.closest("#nav-drawer a")) {
          closeDrawer();
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && drawerIsOpen) closeDrawer();
      });

      // ページ遷移が始まったらドロワーは閉じておく
      document.addEventListener("astro:before-preparation", () => {
        if (drawerIsOpen) closeDrawer();
      });
    </script>

    <script>
      // /lab で切り替えられるエフェクトは全ページで無条件に読み込み、
      // 各エフェクトが自分でlocalStorageのon/off状態を確認して動作する
      import { initLabEffects } from "../lib/lab-effects";
      initLabEffects();
    </script>
  </body>
</html>

---
import { getCollection } from "astro:content";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "月ごとの日記をまとめて記録するサイトです。",
  noindex = false,
} = Astro.props;
const siteName = "蔦南瓜";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;

const pathname = Astro.url.pathname;
const isTop = pathname === "/";
const isDiary = pathname.startsWith("/diary/");

const diaryEntries = await getCollection("diary");
const latestDiaryEntry = [...diaryEntries].sort((a, b) =>
  b.data.yearMonth.localeCompare(a.data.yearMonth)
)[0];
const diaryHref = latestDiaryEntry ? `/diary/${latestDiaryEntry.id}/` : "/";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        var STORAGE_KEY = "theme";
        var stored = localStorage.getItem(STORAGE_KEY);
        var theme =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="ncom-l-container site-header__inner">
        <a href="/" class="site-header__logo">{siteName}</a>
        <nav class="site-header__nav">
          <a href="/" aria-current={isTop ? "page" : undefined}>TOP</a>
          <a href={diaryHref} aria-current={isDiary ? "page" : undefined}
            >DIARY</a
          >
          <button
            type="button"
            id="theme-toggle"
            class="theme-toggle"
            aria-label="ライト/ダークモード切り替え"
          >
            DARK
          </button>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="ncom-l-container">
        <p class="site-footer__copy">&copy; 2026 {siteName}</p>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        height: var(--ncom-header-height);
        background-color: var(--ncom-bg-page);
        border-bottom: 1px solid var(--ncom-color-gray-300);
      }

      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
      }

      .site-header__logo {
        color: var(--ncom-color-heading);
        font-family: var(--ncom-ff-ja);
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 0.03em;
      }

      .site-header__nav {
        display: flex;
        gap: 24px;
      }

      .site-header__nav a {
        color: var(--ncom-color-txt);
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
      }

      .site-header__nav a[aria-current="page"] {
        color: var(--color-primary-dark);
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        padding: 0;
        border: none;
        background: transparent;
        color: var(--ncom-color-txt);
        font-size: 14px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        transition: color 0.15s ease;
      }

      .theme-toggle:hover {
        color: var(--color-primary-dark);
      }

      [data-theme="dark"] .theme-toggle:hover {
        color: var(--color-primary-bright);
      }

      .site-main {
        min-height: calc(100vh - var(--ncom-header-height) - 80px);
      }

      .site-footer {
        background-color: var(--ncom-bg-footer);
        padding: 32px 0;
        margin-top: 64px;
      }

      .site-footer__copy {
        margin: 0;
        color: var(--ncom-color-txt-sub);
        font-family: var(--ncom-ff-roboto);
        font-size: 13px;
      }
    </style>

    <script>
      const STORAGE_KEY = "theme";
      const toggleBtn = document.getElementById(
        "theme-toggle"
      ) as HTMLButtonElement;

      function currentTheme(): "light" | "dark" {
        return document.documentElement.getAttribute("data-theme") === "dark"
          ? "dark"
          : "light";
      }

      function updateToggleLabel() {
        toggleBtn.textContent = currentTheme() === "dark" ? "LIGHT" : "DARK";
      }

      updateToggleLabel();

      toggleBtn.addEventListener("click", () => {
        const next = currentTheme() === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem(STORAGE_KEY, next);
        updateToggleLabel();
      });
    </script>
  </body>
</html>

---
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = "月ごとの日記をまとめて記録するサイトです。",
  noindex = false,
} = Astro.props;
const siteName = "Tsuta Kabocha";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;

const pathname = Astro.url.pathname;
const isTop = pathname === "/";
const isDiary = pathname.startsWith("/diary/");

const diaryEntries = await getCollection("diary");
const latestDiaryEntry = [...diaryEntries].sort((a, b) =>
  b.data.yearMonth.localeCompare(a.data.yearMonth)
)[0];
const diaryHref = latestDiaryEntry ? `/diary/${latestDiaryEntry.id}/` : "/";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        var STORAGE_KEY = "theme";
        function applyStoredTheme() {
          var stored = localStorage.getItem(STORAGE_KEY);
          var theme =
            stored ||
            (window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light");
          document.documentElement.setAttribute("data-theme", theme);
        }
        applyStoredTheme();
        // ClientRouter(View Transitions)でのページ遷移は<html>を遷移先の
        // 生HTML(data-theme属性を持たない)で置き換えるため、ランタイムで
        // 付与したdata-themeが遷移のたびに消えてしまう。astro:after-swap
        // (DOM差し替え直後・描画前)で再適用し、テーマを復元する。
        document.addEventListener("astro:after-swap", applyStoredTheme);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="ncom-l-container site-header__inner">
        <a href="/" class="site-header__logo">{siteName}</a>
        <nav class="site-header__nav">
          <a href="/" aria-current={isTop ? "page" : undefined}>TOP</a>
          <a href={diaryHref} aria-current={isDiary ? "page" : undefined}
            >DIARY</a
          >
          <button
            type="button"
            id="theme-toggle"
            class="theme-toggle theme-toggle-btn"
            aria-label="ライト/ダークモード切り替え"
          >
            DARK
          </button>
        </nav>
      </div>
    </header>

    <button
      type="button"
      id="hamburger-btn"
      class="hamburger-btn"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="hamburger-btn__line"></span>
      <span class="hamburger-btn__line"></span>
      <span class="hamburger-btn__line"></span>
    </button>

    <div class="nav-drawer-overlay" id="nav-drawer-overlay" hidden></div>
    <nav class="nav-drawer" id="nav-drawer" aria-label="メニュー" aria-hidden="true">
      <ul class="nav-drawer__list">
        <li>
          <a
            href="/"
            class="nav-drawer__link"
            aria-current={isTop ? "page" : undefined}
          >
            TOP
          </a>
        </li>
        <li>
          <a
            href={diaryHref}
            class="nav-drawer__link"
            aria-current={isDiary ? "page" : undefined}
          >
            DIARY
          </a>
        </li>
        <li>
          <button
            type="button"
            id="drawer-theme-toggle"
            class="nav-drawer__link theme-toggle-btn"
            aria-label="ライト/ダークモード切り替え"
          >
            DARK
          </button>
        </li>
      </ul>
    </nav>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="ncom-l-container">
        <p class="site-footer__copy">&copy; 2026 {siteName}</p>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        height: var(--ncom-header-height);
        background-color: var(--ncom-bg-page);
        border-bottom: 1px solid var(--ncom-color-gray-300);
        transition: background-color 0.3s ease, color 0.3s ease,
          transform 0.3s ease, opacity 0.3s ease;
      }

      .site-header.is-hidden {
        transform: translateY(-100%);
        opacity: 0;
        pointer-events: none;
      }

      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
      }

      .site-header__logo {
        color: var(--ncom-color-heading);
        font-family: var(--ncom-ff-ja);
        font-size: 16px;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 0.03em;
      }

      .site-header__nav {
        display: flex;
        gap: 24px;
      }

      .site-header__nav a {
        color: var(--ncom-color-txt);
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
      }

      .site-header__nav a[aria-current="page"] {
        color: var(--color-primary-dark);
      }

      [data-theme="dark"] .site-header__nav a {
        color: var(--color-text);
      }

      [data-theme="dark"] .site-header__nav a[aria-current="page"] {
        color: var(--color-primary-bright);
      }

      [data-theme="dark"] .site-header__nav a:hover {
        color: var(--color-primary-bright);
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        padding: 0;
        border: none;
        background: transparent;
        color: var(--ncom-color-txt);
        font-size: 14px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        transition: color 0.15s ease;
      }

      .theme-toggle:hover {
        color: var(--color-primary-dark);
      }

      [data-theme="dark"] .theme-toggle:hover {
        color: var(--color-primary-bright);
      }

      .hamburger-btn {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 4px;
        background: none;
        cursor: pointer;
        opacity: 0;
        transform: scale(0.85);
        pointer-events: none;
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .hamburger-btn.is-visible {
        opacity: 1;
        transform: scale(1);
        pointer-events: auto;
      }

      .hamburger-btn__line {
        display: block;
        width: 22px;
        height: 2px;
        background-color: var(--color-primary-dark);
        transition: transform 0.25s ease, opacity 0.25s ease,
          background-color 0.3s ease;
      }

      [data-theme="dark"] .hamburger-btn__line {
        background-color: var(--color-primary-bright);
      }

      .hamburger-btn[aria-expanded="true"] .hamburger-btn__line:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
      }

      .hamburger-btn[aria-expanded="true"] .hamburger-btn__line:nth-child(2) {
        opacity: 0;
      }

      .hamburger-btn[aria-expanded="true"] .hamburger-btn__line:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
      }

      .nav-drawer-overlay {
        position: fixed;
        inset: 0;
        z-index: 1001;
        background: rgba(0, 0, 0, 0.3);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
      }

      .nav-drawer-overlay.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .nav-drawer {
        position: fixed;
        top: 56px;
        right: 16px;
        z-index: 1002;
        display: flex;
        flex-direction: column;
        min-width: 140px;
        padding: 8px;
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
        opacity: 0;
        transform: translateY(-8px);
        pointer-events: none;
        transition: opacity 0.2s ease, transform 0.2s ease,
          background-color 0.3s ease;
      }

      .nav-drawer.is-open {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .nav-drawer__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .nav-drawer__link {
        display: block;
        width: 100%;
        padding: 14px 12px;
        border: none;
        border-radius: 4px;
        background: transparent;
        color: var(--ncom-color-heading);
        font-family: var(--ncom-ff-ja);
        font-size: 16px;
        font-weight: 700;
        text-align: left;
        text-decoration: none;
        cursor: pointer;
        transition: background-color 0.15s ease, color 0.15s ease;
      }

      .nav-drawer__link:hover {
        background-color: var(--ncom-bg-surface-100);
        opacity: 1;
      }

      .nav-drawer__link[aria-current="page"] {
        color: var(--color-primary-dark);
      }

      [data-theme="dark"] .nav-drawer__link[aria-current="page"] {
        color: var(--color-primary-bright);
      }

      .site-main {
        min-height: calc(100vh - var(--ncom-header-height) - 80px);
      }

      .site-footer {
        background-color: var(--ncom-bg-footer);
        padding: 32px 0;
        margin-top: 64px;
      }

      .site-footer__copy {
        margin: 0;
        color: var(--ncom-color-txt-sub);
        font-family: var(--ncom-ff-roboto);
        font-size: 13px;
      }
    </style>

    <script>
      // ClientRouter(View Transitions)導入後は、同一の<script>がページ遷移のたびに
      // 再実行されるとは限らず、また遷移でdocument.body配下の要素は丸ごと
      // 差し替えられる(参照を保持していると古いDOMを掴んだままになる)。
      // そのため要素への参照は都度取得し直し、クリック等はdocumentへの
      // イベント委任で受け止めることで、遷移後の新しいDOMにも自然に追従させる。

      const STORAGE_KEY = "theme";

      function currentTheme(): "light" | "dark" {
        return document.documentElement.getAttribute("data-theme") === "dark"
          ? "dark"
          : "light";
      }

      function updateToggleLabels() {
        const label = currentTheme() === "dark" ? "LIGHT" : "DARK";
        document
          .querySelectorAll<HTMLButtonElement>(".theme-toggle-btn")
          .forEach((btn) => {
            btn.textContent = label;
          });
      }

      function toggleTheme() {
        const next = currentTheme() === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem(STORAGE_KEY, next);
        updateToggleLabels();
        refreshTweetEmbeds();
        reloadTweetEmbeds();
      }

      // 埋め込みツイートはビルド時に静的生成されるため、data-theme はここで
      // クライアント側から都度上書きし、twttr.widgets.load() で反映させる。
      // 対象は未描画の<blockquote class="twitter-tweet">のみ(タグ名で絞る)。
      // widgets.jsは描画後、blockquoteを<div class="twitter-tweet twitter-tweet-rendered">
      // に置き換えるため、classだけで絞るとその置き換え後のdivまで拾ってしまう。
      function refreshTweetEmbeds() {
        const isDark = currentTheme() === "dark";
        document
          .querySelectorAll<HTMLElement>("blockquote.twitter-tweet")
          .forEach((el) => {
            el.setAttribute("data-theme", isDark ? "dark" : "light");
          });
        const twttr = (window as unknown as {
          twttr?: { widgets?: { load: () => void } };
        }).twttr;
        twttr?.widgets?.load();
      }

      // widgets.jsは描画時に<blockquote>を全く別のDOM要素(現行仕様では
      // <div class="twitter-tweet twitter-tweet-rendered">、旧仕様では
      // <twitter-widget>の場合もある)に差し替えてしまい、data-theme等の
      // カスタム属性も元の<a href>も引き継がれない。再度widgets.load()を
      // 呼んでもこの差し替え後の要素は「描画済み」として無視されるため、
      // 一度<blockquote>の形に戻してから再描画する必要がある。
      // URLは差し替え後の要素からは復元できないため、diary.tsで
      // ラッパー(.diary-embed-tweet)側に控えておいたdata-original-urlから読む。
      //
      // .diary-embed-tweet(ラッパー)自体は一切操作しない。ラッパー単位で
      // 走査し、中身を常に「新しいblockquote1つだけ」に揃えることで、
      // 短時間に連続でテーマ切り替えが行われてwidgets.jsの非同期描画が
      // 重なった場合でも、描画途中の要素がラッパー内に孤児として溜まって
      // flexの中央寄せが崩れる(結果的に左寄りに見える)ことを防ぐ。
      function reloadTweetEmbeds() {
        document
          .querySelectorAll<HTMLElement>(".diary-embed-tweet")
          .forEach((wrapper) => {
            const hasRendered = wrapper.querySelector(
              ".twitter-tweet-rendered, twitter-widget"
            );
            if (!hasRendered) return; // まだ未描画のラッパーは対象外

            const url = wrapper.getAttribute("data-original-url") ?? "";
            if (!url) return; // URLが復元できない場合は空のblockquoteを作らない

            const blockquote = document.createElement("blockquote");
            blockquote.className = "twitter-tweet";
            blockquote.setAttribute(
              "data-theme",
              currentTheme() === "dark" ? "dark" : "light"
            );
            const anchor = document.createElement("a");
            anchor.href = url;
            blockquote.appendChild(anchor);
            wrapper.replaceChildren(blockquote);
          });

        const twttr = (window as unknown as {
          twttr?: { widgets?: { load: () => void } };
        }).twttr;
        twttr?.widgets?.load();
      }

      // widgets.js(非同期読み込み)がastro:page-loadより先にツイートを
      // 描画し終えてしまうことがあり、その場合data-theme修正が間に合わず
      // 誤ったテーマのまま固定されてしまう。twttr.events.bind('rendered', ...)
      // に頼らず、.diary-embed-tweet直下の子要素の変化をMutationObserverで
      // 直接監視し、描画済み要素(twitter-widget / .twitter-tweet-rendered)が
      // 追加された瞬間に捉えて補正する。
      //
      // 補正はreloadTweetEmbeds()自身が「未描画→描画済み」への差し替えを
      // 引き起こすため、無条件にreloadTweetEmbeds()を呼ぶと
      // 描画→検知→reload→再描画→再検知→…と無限ループになってしまう。
      // 実際に描画されたiframeのtheme(src中のクエリパラメータ)と
      // 現在のテーマを比較し、食い違っている場合だけ呼ぶことでこれを防ぐ
      // (一致していれば何もしないため、ループはそこで止まる)。
      let tweetObserver: MutationObserver | null = null;

      function watchTweetTheme() {
        if (tweetObserver) {
          tweetObserver.disconnect();
          tweetObserver = null;
        }

        const wrappers = document.querySelectorAll<HTMLElement>(
          ".diary-embed-tweet"
        );
        if (wrappers.length === 0) return; // ツイートがないページは何もしない

        tweetObserver = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            let iframe: HTMLIFrameElement | null = null;

            // widgets.jsはまず(srcが空の)<iframe>を含むコンテナを挿入し、
            // 実際のsrc属性は少し遅れて別のmutationとして設定する。
            // そのためchildList側だけでなく、iframeのsrc属性が実際に
            // 設定された瞬間(attributes mutation)も監視対象にする。
            if (
              mutation.type === "attributes" &&
              mutation.attributeName === "src" &&
              mutation.target instanceof HTMLIFrameElement
            ) {
              iframe = mutation.target;
            } else if (mutation.type === "childList") {
              for (const node of Array.from(mutation.addedNodes)) {
                const el = node as HTMLElement;
                const isRenderedNode =
                  el.nodeName === "TWITTER-WIDGET" ||
                  (el.classList?.contains("twitter-tweet-rendered") ?? false);
                if (!isRenderedNode) continue;

                const found =
                  el.nodeName === "IFRAME"
                    ? (el as unknown as HTMLIFrameElement)
                    : el.querySelector<HTMLIFrameElement>("iframe");
                if (found?.src) iframe = found; // srcが未設定ならこの時点ではまだ判定しない
              }
            }

            if (!iframe || !iframe.src) continue;

            let renderedTheme: string | null = null;
            try {
              renderedTheme = new URL(iframe.src).searchParams.get("theme");
            } catch {
              continue;
            }
            // iframeのthemeと現在のthemeが違う場合のみreload
            if (renderedTheme !== currentTheme()) {
              reloadTweetEmbeds();
            }
            return; // 1回のmutationで複数発火しないようにreturn
          }
        });

        // .diary-embed-tweetコンテナを監視する。widgets.jsは描画時、まず
        // 空の(または未完成の)コンテナ要素をラッパーの直接の子として挿入し、
        // 続けてその内側にiframeを追加、さらにその後iframeのsrc属性を
        // 設定するという多段階の処理を行う。そのため
        // childList(挿入) + subtree(内側のiframeまで) + attributes(src設定)
        // のすべてを監視対象にする。
        wrappers.forEach((wrapper) => {
          tweetObserver!.observe(wrapper, {
            childList: true,
            subtree: true,
            attributes: true,
            attributeFilter: ["src"],
          });
        });
      }

      updateToggleLabels();
      refreshTweetEmbeds();
      watchTweetTheme();
      document.addEventListener("astro:page-load", () => {
        updateToggleLabels();
        // widgets.js(非同期読み込み)の自動描画は、まだ未描画の<blockquote>を
        // refreshTweetEmbeds()がdata-theme修正するより先に走ってしまうことがある
        // (実測でも数百ms単位の競合が確認できる)。その場合、遷移直後の
        // refreshTweetEmbeds()だけでは既に描画済みのカードを直せないため、
        // reloadTweetEmbeds()も必ず合わせて呼び、どちらが先に完了しても
        // 最終的に正しいテーマで表示されるようにする。
        refreshTweetEmbeds();
        reloadTweetEmbeds();
        // 遷移後は.diary-embed-tweetの実体も入れ替わっているため、
        // observerを毎回張り直す。
        watchTweetTheme();
      });

      // --- テーマ切り替えのリップルアニメーション(lab効果の設定に関係なく常に動作する) ---
      const THEME_RIPPLE_DURATION = 400;

      function triggerThemeRipple(x: number, y: number) {
        const color =
          currentTheme() === "dark"
            ? "rgba(217, 242, 223, 0.5)" // ダーク→ライト: 薄いグリーン系
            : "rgba(0, 38, 20, 0.15)"; // ライト→ダーク: 暗い緑系
        const maxRadius = Math.hypot(
          Math.max(x, window.innerWidth - x),
          Math.max(y, window.innerHeight - y)
        );
        const overlay = document.createElement("div");
        overlay.className = "theme-ripple";
        overlay.style.setProperty("--x", `${x}px`);
        overlay.style.setProperty("--y", `${y}px`);
        overlay.style.setProperty("--r", `${maxRadius}px`);
        overlay.style.setProperty("--ripple-color", color);
        document.body.appendChild(overlay);

        void overlay.offsetHeight; // reflowを強制してtransitionを確実に発火させる
        overlay.classList.add("is-expanding");

        // リップルが画面の半分程度まで広がったタイミングでテーマを切り替える
        window.setTimeout(toggleTheme, THEME_RIPPLE_DURATION / 2);
        window.setTimeout(() => overlay.remove(), THEME_RIPPLE_DURATION);
      }

      // --- ページ最上部でのみヘッダーを表示し、それ以外はハンバーガーボタンに切り替える ---
      const SCROLL_TOP_THRESHOLD = 10;
      let headerHidden = false;
      let scrollTicking = false;

      function updateHeaderVisibility() {
        scrollTicking = false;
        const header = document.getElementById("site-header");
        const hamburgerBtn = document.getElementById("hamburger-btn");
        if (!header || !hamburgerBtn) return;

        const atTop = window.scrollY < SCROLL_TOP_THRESHOLD;

        if (!atTop && !headerHidden) {
          headerHidden = true;
          header.classList.add("is-hidden");
          hamburgerBtn.classList.add("is-visible");
        } else if (atTop && headerHidden) {
          headerHidden = false;
          header.classList.remove("is-hidden");
          hamburgerBtn.classList.remove("is-visible");
        }
      }

      window.addEventListener(
        "scroll",
        () => {
          if (!scrollTicking) {
            scrollTicking = true;
            requestAnimationFrame(updateHeaderVisibility);
          }
        },
        { passive: true }
      );

      // 遷移直後は新しいページの先頭から見せたいので、ヘッダーの表示状態をリセットする
      document.addEventListener("astro:page-load", () => {
        headerHidden = false;
        document.getElementById("site-header")?.classList.remove("is-hidden");
        document
          .getElementById("hamburger-btn")
          ?.classList.remove("is-visible");
      });

      // --- ドロワーメニュー ---
      let drawerIsOpen = false;

      function openDrawer() {
        const drawer = document.getElementById("nav-drawer");
        const overlay = document.getElementById("nav-drawer-overlay");
        const hamburgerBtn = document.getElementById("hamburger-btn");
        if (!drawer || !overlay || !hamburgerBtn) return;
        drawerIsOpen = true;
        overlay.hidden = false;
        void overlay.offsetHeight; // reflowを強制してtransitionを確実に発火させる
        drawer.classList.add("is-open");
        overlay.classList.add("is-open");
        drawer.setAttribute("aria-hidden", "false");
        hamburgerBtn.setAttribute("aria-expanded", "true");
      }

      function closeDrawer() {
        if (!drawerIsOpen) return;
        drawerIsOpen = false;
        const drawer = document.getElementById("nav-drawer");
        const overlay = document.getElementById("nav-drawer-overlay");
        const hamburgerBtn = document.getElementById("hamburger-btn");
        drawer?.classList.remove("is-open");
        overlay?.classList.remove("is-open");
        drawer?.setAttribute("aria-hidden", "true");
        hamburgerBtn?.setAttribute("aria-expanded", "false");
        window.setTimeout(() => {
          if (!drawerIsOpen && overlay) overlay.hidden = true;
        }, 200);
      }

      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement | null;
        if (!target) return;

        if (target.closest("#hamburger-btn")) {
          drawerIsOpen ? closeDrawer() : openDrawer();
          return;
        }
        if (target.id === "nav-drawer-overlay") {
          closeDrawer();
          return;
        }
        const themeToggleBtn = target.closest(".theme-toggle-btn");
        if (themeToggleBtn) {
          const rect = themeToggleBtn.getBoundingClientRect();
          const x = rect.left + rect.width / 2;
          const y = rect.top + rect.height / 2;
          triggerThemeRipple(x, y);
          return;
        }
        // ドロワー内のリンクをクリックした場合(=遷移する場合)は閉じておく
        if (drawerIsOpen && target.closest("#nav-drawer a")) {
          closeDrawer();
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && drawerIsOpen) closeDrawer();
      });

      // ページ遷移が始まったらドロワーは閉じておく
      document.addEventListener("astro:before-preparation", () => {
        if (drawerIsOpen) closeDrawer();
      });
    </script>

    <script>
      // /lab で切り替えられるエフェクトは全ページで無条件に読み込み、
      // 各エフェクトが自分でlocalStorageのon/off状態を確認して動作する
      import { initLabEffects } from "../lib/lab-effects";
      initLabEffects();
    </script>
  </body>
</html>

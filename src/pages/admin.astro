---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="日記投稿" description="日記投稿管理ページ" noindex>
  <div class="ncom-l-container admin-page">
    <section id="login-section" class="login-card">
      <h1>日記投稿</h1>
      <p class="login-card__lead">パスワードを入力してください。</p>
      <form id="login-form" class="login-form">
        <input
          type="password"
          id="login-password"
          name="password"
          placeholder="パスワード"
          autocomplete="current-password"
          required
        />
        <button type="submit" class="ncom-c-cta-btn">ログイン</button>
      </form>
      <p id="login-error" class="feedback feedback--error" hidden></p>
    </section>

    <section id="post-section" class="post-section" hidden>
      <pre id="bg-text" class="bg-text" aria-hidden="true"></pre>

      <div class="post-section__header">
        <h1>日記投稿</h1>
        <button type="button" id="logout-btn" class="logout-btn">ログアウト</button>
      </div>

      <div class="tabs" role="tablist">
        <button
          type="button"
          class="tab-btn active"
          data-tab="single"
          role="tab"
          aria-selected="true"
        >
          通常投稿
        </button>
        <button
          type="button"
          class="tab-btn"
          data-tab="bulk"
          role="tab"
          aria-selected="false"
        >
          一括インポート
        </button>
        <button
          type="button"
          class="tab-btn"
          data-tab="edit"
          role="tab"
          aria-selected="false"
        >
          編集
        </button>
      </div>

      <div class="media-upload">
        <label class="media-upload__label" for="media-file">メディアを挿入</label>
        <input
          type="file"
          id="media-file"
          accept="image/*,audio/*,video/*"
          multiple
        />
      </div>
      <ul id="media-queue" class="media-queue"></ul>

      <form id="single-form" class="tab-panel">
        <label class="field">
          <span class="field__label">日付</span>
          <input type="date" id="single-date" name="date" required />
        </label>
        <label class="field">
          <span class="field__label">本文</span>
          <textarea
            id="single-content"
            name="content"
            rows="10"
            placeholder="今日の出来事を書く"
            required></textarea>
        </label>
        <button type="submit" class="ncom-c-cta-btn">投稿する</button>
      </form>

      <form id="bulk-form" class="tab-panel">
        <label class="field">
          <span class="field__label">インポートするテキスト</span>
          <textarea
            id="bulk-content"
            name="content"
            rows="20"
            placeholder={"260714\n本文…\n\n段落を分けたい場合は空行を入れる\n\n260715\n翌日の本文…"}
            required></textarea>
        </label>
        <button type="submit" class="ncom-c-cta-btn">インポートする</button>
      </form>

      <form id="edit-form" class="tab-panel">
        <label class="field">
          <span class="field__label">編集する月</span>
          <select id="edit-month-select">
            <option value="">月を選択してください</option>
          </select>
        </label>
        <label class="field">
          <span class="field__label">本文（Markdown全体）</span>
          <textarea
            id="edit-content"
            name="content"
            rows="20"
            placeholder="月を選択すると読み込まれます"></textarea>
        </label>
        <button type="submit" id="edit-save-btn" class="ncom-c-cta-btn" disabled
          >上書き保存する</button
        >
      </form>

      <p id="post-feedback" class="feedback" hidden></p>
    </section>
  </div>

  <style>
    .admin-page {
      max-width: 720px;
      padding: 64px 24px 96px;
    }

    .login-card {
      max-width: 360px;
      margin: 0 auto;
    }

    .login-card__lead {
      margin: 16px 0 24px;
      color: var(--ncom-color-txt-sub);
    }

    .login-form {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .login-form input[type="password"] {
      height: 48px;
      padding: 0 16px;
      border: 1px solid var(--ncom-color-gray-500);
      border-radius: 2px;
      background-color: var(--ncom-bg-surface-300);
      font-family: var(--ncom-ff-ja);
      font-size: 16px;
    }

    .post-section {
      position: relative;
    }

    .bg-text {
      position: absolute;
      inset: 0;
      z-index: -1;
      margin: 0;
      padding: 0;
      overflow: hidden;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: var(--ncom-ff-ja);
      font-size: 16px;
      line-height: 1.8;
      color: var(--ncom-color-txt);
      opacity: 0.1;
      pointer-events: none;
      user-select: none;
    }

    .post-section__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
    }

    .logout-btn {
      border: 1px solid var(--ncom-color-gray-500);
      border-radius: 2px;
      background: transparent;
      color: var(--ncom-color-txt-sub);
      padding: 8px 16px;
      font-family: var(--ncom-ff-ja);
      font-size: 14px;
      cursor: pointer;
    }

    .logout-btn:hover {
      opacity: 0.7;
    }

    .tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 24px;
      border-bottom: 1px solid var(--ncom-color-gray-300);
    }

    .tab-btn {
      padding: 12px 20px;
      border: none;
      border-bottom: 2px solid transparent;
      background: transparent;
      color: var(--ncom-color-txt-sub);
      font-family: var(--ncom-ff-ja);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
    }

    .tab-btn.active {
      border-bottom-color: var(--color-primary);
      color: var(--ncom-color-heading);
    }

    .tab-panel {
      display: none;
      flex-direction: column;
      gap: 20px;
    }

    .media-upload {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 24px;
      padding: 16px;
      border: 1px solid var(--ncom-color-gray-500);
      border-radius: 2px;
      background-color: var(--ncom-bg-surface-100);
    }

    .media-upload__label {
      color: var(--ncom-color-txt-sub);
      font-size: 14px;
      font-weight: 700;
      white-space: nowrap;
    }

    .media-upload input[type="file"] {
      font-family: var(--ncom-ff-ja);
      font-size: 14px;
    }

    .media-queue {
      list-style: none;
      margin: 0 0 24px;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .media-queue:empty {
      display: none;
    }

    .media-queue__item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 16px;
      border: 1px solid var(--ncom-color-gray-500);
      border-radius: 2px;
      background-color: var(--ncom-bg-surface-100);
      font-size: 14px;
    }

    .media-queue__name {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: var(--ncom-color-txt);
    }

    .media-queue__meta {
      flex-shrink: 0;
      color: var(--ncom-color-txt-sub);
      font-family: var(--ncom-ff-roboto);
      font-size: 14px;
    }

    .media-queue__item--uploading {
      border-color: var(--color-primary);
    }

    .media-queue__item--uploading .media-queue__meta {
      color: var(--color-primary);
    }

    .media-queue__item--done .media-queue__meta {
      color: var(--color-success-text);
    }

    .media-queue__item--error {
      background-color: var(--color-danger-bg);
    }

    .media-queue__item--error .media-queue__meta {
      color: var(--ncom-color-deep-red);
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .field__label {
      color: var(--ncom-color-txt-sub);
      font-size: 14px;
      font-weight: 700;
    }

    .field input[type="date"] {
      height: 48px;
      padding: 0 16px;
      border: 1px solid var(--ncom-color-gray-500);
      border-radius: 2px;
      background-color: var(--ncom-bg-surface-300);
      font-family: var(--ncom-ff-roboto);
      font-size: 16px;
      width: fit-content;
    }

    .field select {
      height: 48px;
      padding: 0 16px;
      border: 1px solid var(--ncom-color-gray-500);
      border-radius: 2px;
      background-color: var(--ncom-bg-surface-300);
      font-family: var(--ncom-ff-ja);
      font-size: 16px;
      width: fit-content;
    }

    .ncom-c-cta-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .field textarea {
      padding: 16px;
      border: 1px solid var(--ncom-color-gray-500);
      border-radius: 2px;
      background-color: var(--ncom-bg-page);
      font-family: var(--ncom-ff-ja);
      font-size: 16px;
      line-height: 1.8;
      resize: vertical;
    }

    .ncom-c-cta-btn {
      align-self: flex-start;
      border: none;
      cursor: pointer;
    }

    .feedback {
      margin-top: 20px;
      padding: 16px;
      border-radius: 2px;
      background-color: var(--ncom-bg-surface-100);
      color: var(--ncom-color-txt);
      font-size: 14px;
    }

    .feedback--error {
      background-color: var(--color-danger-bg);
      color: var(--ncom-color-deep-red);
    }

    .feedback--success {
      background-color: var(--color-success-bg);
      color: var(--color-success-text);
    }
  </style>

  <script>
    const STORAGE_KEY = "diary_admin_password";
    const GITHUB_OWNER = "TsutaKabocha";
    const GITHUB_REPO = "mysite";
    const DIARY_DIR = "src/content/diary";

    const loginSection = document.getElementById(
      "login-section"
    ) as HTMLElement;
    const postSection = document.getElementById(
      "post-section"
    ) as HTMLElement;
    const loginForm = document.getElementById("login-form") as HTMLFormElement;
    const loginPasswordInput = document.getElementById(
      "login-password"
    ) as HTMLInputElement;
    const loginError = document.getElementById("login-error") as HTMLElement;
    const logoutBtn = document.getElementById("logout-btn") as HTMLElement;

    const tabBtns = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".tab-btn")
    );

    const singleForm = document.getElementById(
      "single-form"
    ) as HTMLFormElement;
    const singleDateInput = document.getElementById(
      "single-date"
    ) as HTMLInputElement;
    const singleContentInput = document.getElementById(
      "single-content"
    ) as HTMLTextAreaElement;

    const bulkForm = document.getElementById("bulk-form") as HTMLFormElement;
    const bulkContentInput = document.getElementById(
      "bulk-content"
    ) as HTMLTextAreaElement;

    const bgText = document.getElementById("bg-text") as HTMLElement;

    const editForm = document.getElementById("edit-form") as HTMLFormElement;
    const editMonthSelect = document.getElementById(
      "edit-month-select"
    ) as HTMLSelectElement;
    const editContentInput = document.getElementById(
      "edit-content"
    ) as HTMLTextAreaElement;
    const editSaveBtn = document.getElementById(
      "edit-save-btn"
    ) as HTMLButtonElement;

    const postFeedback = document.getElementById(
      "post-feedback"
    ) as HTMLElement;

    const mediaFileInput = document.getElementById(
      "media-file"
    ) as HTMLInputElement;
    const mediaQueueList = document.getElementById(
      "media-queue"
    ) as HTMLElement;

    const tabPanels: Record<string, HTMLElement> = {
      single: singleForm,
      bulk: bulkForm,
      edit: editForm,
    };

    const tabTextareas: Record<string, HTMLTextAreaElement> = {
      single: singleContentInput,
      bulk: bulkContentInput,
      edit: editContentInput,
    };

    let currentTab = "single";
    let backgroundLoaded = false;
    let editMonthsLoaded = false;

    function decodeBase64Utf8(base64: string): string {
      const binary = atob(base64.replace(/\n/g, ""));
      const bytes = Uint8Array.from(binary, (c) => c.charCodeAt(0));
      return new TextDecoder("utf-8").decode(bytes);
    }

    function currentYearMonth(): string {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, "0");
      return `${y}-${m}`;
    }

    async function githubGetFileContent(path: string): Promise<string | null> {
      try {
        const res = await fetch(
          `https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/${path}`
        );
        if (!res.ok) return null;
        const data = (await res.json()) as { content: string };
        return decodeBase64Utf8(data.content);
      } catch {
        return null;
      }
    }

    async function githubListDiaryMonths(): Promise<string[]> {
      try {
        const res = await fetch(
          `https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/${DIARY_DIR}`
        );
        if (!res.ok) return [];
        const data = (await res.json()) as { name: string; type: string }[];
        return data
          .filter(
            (item) => item.type === "file" && /^\d{4}-\d{2}\.md$/.test(item.name)
          )
          .map((item) => item.name.replace(/\.md$/, ""))
          .sort()
          .reverse();
      } catch {
        return [];
      }
    }

    async function loadBackgroundText() {
      const content = await githubGetFileContent(
        `${DIARY_DIR}/${currentYearMonth()}.md`
      );
      if (content) {
        bgText.textContent = content;
      }
    }

    async function populateEditMonths() {
      const months = await githubListDiaryMonths();
      for (const month of months) {
        const option = document.createElement("option");
        option.value = month;
        option.textContent = month;
        editMonthSelect.appendChild(option);
      }
    }

    function todayIso(): string {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, "0");
      const d = String(now.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function showPostUI() {
      loginSection.hidden = true;
      postSection.hidden = false;
      singleDateInput.value = todayIso();
      if (!backgroundLoaded) {
        backgroundLoaded = true;
        loadBackgroundText();
      }
      if (!editMonthsLoaded) {
        editMonthsLoaded = true;
        populateEditMonths();
      }
    }

    function showLoginUI(message?: string) {
      postSection.hidden = true;
      loginSection.hidden = false;
      if (message) {
        loginError.textContent = message;
        loginError.hidden = false;
      } else {
        loginError.hidden = true;
      }
    }

    function getStoredPassword(): string | null {
      return sessionStorage.getItem(STORAGE_KEY);
    }

    function setStoredPassword(password: string) {
      sessionStorage.setItem(STORAGE_KEY, password);
    }

    function clearStoredPassword() {
      sessionStorage.removeItem(STORAGE_KEY);
    }

    function setFeedback(message: string, ok: boolean) {
      postFeedback.textContent = message;
      postFeedback.hidden = false;
      postFeedback.classList.toggle("feedback--success", ok);
      postFeedback.classList.toggle("feedback--error", !ok);
    }

    async function submitDiary(body: Record<string, unknown>) {
      const password = getStoredPassword();
      if (!password) {
        showLoginUI();
        return;
      }

      const res = await fetch("/.netlify/functions/diary-post", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ password, ...body }),
      });

      const result = await res.json().catch(() => ({
        success: false,
        message: "サーバーからの応答を読み取れませんでした",
      }));

      if (res.status === 401) {
        clearStoredPassword();
        showLoginUI("パスワードが違います。もう一度入力してください。");
        return;
      }

      setFeedback(result.message ?? "", Boolean(result.success));
    }

    loginForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const password = loginPasswordInput.value;
      if (!password) return;
      setStoredPassword(password);
      loginPasswordInput.value = "";
      showPostUI();
    });

    logoutBtn.addEventListener("click", () => {
      clearStoredPassword();
      postFeedback.hidden = true;
      showLoginUI();
    });

    function activateTab(target: string) {
      currentTab = target;
      tabBtns.forEach((btn) => {
        const isActive = btn.dataset.tab === target;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-selected", String(isActive));
      });
      for (const [key, panel] of Object.entries(tabPanels)) {
        panel.style.display = key === target ? "flex" : "none";
      }
      postFeedback.hidden = true;
    }

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.tab;
        if (target) activateTab(target);
      });
    });

    activateTab("single");

    singleForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      await submitDiary({
        date: singleDateInput.value,
        content: singleContentInput.value,
        mode: "single",
      });
      singleContentInput.value = "";
    });

    bulkForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      await submitDiary({
        content: bulkContentInput.value,
        mode: "bulk",
      });
      bulkContentInput.value = "";
    });

    editMonthSelect.addEventListener("change", async () => {
      const month = editMonthSelect.value;
      editSaveBtn.disabled = true;
      if (!month) {
        editContentInput.value = "";
        return;
      }
      editContentInput.value = "読み込み中…";
      const content = await githubGetFileContent(`${DIARY_DIR}/${month}.md`);
      if (content === null) {
        editContentInput.value = "";
        setFeedback("ファイルの取得に失敗しました", false);
        return;
      }
      editContentInput.value = content;
      editSaveBtn.disabled = false;
    });

    editForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const month = editMonthSelect.value;
      if (!month) return;
      await submitDiary({
        mode: "overwrite",
        filename: `${month}.md`,
        content: editContentInput.value,
      });
    });

    function insertAtCursor(textarea: HTMLTextAreaElement, text: string) {
      const start = textarea.selectionStart ?? textarea.value.length;
      const end = textarea.selectionEnd ?? textarea.value.length;
      textarea.value =
        textarea.value.slice(0, start) + text + textarea.value.slice(end);
      const cursor = start + text.length;
      textarea.selectionStart = textarea.selectionEnd = cursor;
      textarea.focus();
    }

    interface QueueItem {
      id: string;
      file: File;
      status: "queued" | "uploading" | "done" | "error";
      progress: number;
      errorMessage?: string;
    }

    interface PresignResult {
      success: boolean;
      message?: string;
      uploadUrl?: string;
      url?: string;
      filename?: string;
      contentType?: string;
    }

    interface PutResult {
      success: boolean;
      message?: string;
    }

    let uploadQueue: QueueItem[] = [];
    let isUploading = false;

    function formatFileSize(bytes: number): string {
      if (bytes < 1024) return `${bytes}B`;
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)}KB`;
      return `${(bytes / (1024 * 1024)).toFixed(1)}MB`;
    }

    function renderQueue() {
      mediaQueueList.innerHTML = "";
      for (const item of uploadQueue) {
        const li = document.createElement("li");
        li.className = `media-queue__item media-queue__item--${item.status}`;

        const name = document.createElement("span");
        name.className = "media-queue__name";
        name.textContent = item.file.name;

        const meta = document.createElement("span");
        meta.className = "media-queue__meta";
        if (item.status === "queued") {
          meta.textContent = formatFileSize(item.file.size);
        } else if (item.status === "uploading") {
          meta.textContent = `${item.progress}%`;
        } else if (item.status === "done") {
          meta.textContent = "✓";
        } else {
          meta.textContent = item.errorMessage ?? "失敗";
        }

        li.append(name, meta);
        mediaQueueList.appendChild(li);
      }
    }

    // Netlify Functionsの同期リクエストは6MB(バイナリは実質4.5MB)までしか受け付けられず、
    // 動画などの大きいファイルをそのままPOSTすると本文がプラットフォーム側で拒否され、
    // JSONではないレスポンスが返って「サーバーからの応答を読み取れませんでした」になっていた。
    // そのためファイル本体はこの関数を経由させず、署名付きURLをJSONで取得してから
    // ブラウザからR2へ直接PUTする(この関数へのリクエストは常に小さいJSONのみ)。
    async function requestUploadUrl(
      file: File,
      password: string
    ): Promise<PresignResult> {
      try {
        const res = await fetch("/.netlify/functions/media-upload", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            password,
            filename: file.name,
            contentType: file.type || "application/octet-stream",
            size: file.size,
          }),
        });

        const result = await res.json().catch(() => ({
          success: false,
          message: "サーバーからの応答を読み取れませんでした",
        }));

        if (res.status === 401) {
          clearStoredPassword();
          showLoginUI("パスワードが違います。もう一度入力してください。");
        }

        return result;
      } catch {
        return { success: false, message: "通信エラーが発生しました" };
      }
    }

    function putFileWithProgress(
      uploadUrl: string,
      file: File,
      contentType: string,
      onProgress: (percent: number) => void
    ): Promise<PutResult> {
      return new Promise((resolve) => {
        const xhr = new XMLHttpRequest();
        xhr.open("PUT", uploadUrl);
        xhr.setRequestHeader("Content-Type", contentType);

        xhr.upload.addEventListener("progress", (e) => {
          if (e.lengthComputable) {
            onProgress(Math.round((e.loaded / e.total) * 100));
          }
        });

        xhr.addEventListener("load", () => {
          if (xhr.status >= 200 && xhr.status < 300) {
            resolve({ success: true });
          } else {
            resolve({
              success: false,
              message: `R2へのアップロードに失敗しました(status ${xhr.status})`,
            });
          }
        });

        xhr.addEventListener("error", () => {
          resolve({ success: false, message: "R2への通信エラーが発生しました" });
        });

        xhr.send(file);
      });
    }

    async function processQueue() {
      if (isUploading) return;
      const next = uploadQueue.find((item) => item.status === "queued");
      if (!next) return;

      isUploading = true;
      next.status = "uploading";
      next.progress = 0;
      renderQueue();

      const password = getStoredPassword();
      if (!password) {
        next.status = "error";
        next.errorMessage = "ログインが必要です";
        renderQueue();
        isUploading = false;
        showLoginUI();
        return;
      }

      const presign = await requestUploadUrl(next.file, password);

      if (
        !presign.success ||
        !presign.uploadUrl ||
        !presign.url ||
        !presign.filename
      ) {
        next.status = "error";
        next.errorMessage = presign.message ?? "アップロードに失敗しました";
        renderQueue();
        isUploading = false;
        processQueue();
        return;
      }

      const contentType =
        presign.contentType || next.file.type || "application/octet-stream";

      const putResult = await putFileWithProgress(
        presign.uploadUrl,
        next.file,
        contentType,
        (percent) => {
          next.progress = percent;
          renderQueue();
        }
      );

      if (!putResult.success) {
        next.status = "error";
        next.errorMessage = putResult.message ?? "アップロードに失敗しました";
        renderQueue();
      } else {
        next.status = "done";
        next.progress = 100;
        renderQueue();

        const snippet = contentType.startsWith("image/")
          ? `![${presign.filename}](${presign.url})`
          : `[${presign.filename}](${presign.url})`;

        insertAtCursor(tabTextareas[currentTab] ?? singleContentInput, snippet);
        setFeedback(`アップロードしました: ${presign.filename}`, true);

        const doneId = next.id;
        setTimeout(() => {
          uploadQueue = uploadQueue.filter((item) => item.id !== doneId);
          renderQueue();
        }, 2500);
      }

      isUploading = false;
      processQueue();
    }

    mediaFileInput.addEventListener("change", () => {
      const files = mediaFileInput.files;
      if (files && files.length > 0) {
        for (const file of Array.from(files)) {
          uploadQueue.push({
            id: crypto.randomUUID(),
            file,
            status: "queued",
            progress: 0,
          });
        }
        renderQueue();
        processQueue();
      }
      mediaFileInput.value = "";
    });

    if (getStoredPassword()) {
      showPostUI();
    }
  </script>
</BaseLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  parseDiaryEntries,
  renderDiaryMarkdown,
  formatYearMonthCompact,
  formatYearMonthLong,
} from "../../lib/diary";

export async function getStaticPaths() {
  const entries = await getCollection("diary");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const diaryGroups = parseDiaryEntries(entry.body ?? "").map((group) => ({
  ...group,
  bodies: group.bodies.map((body) => renderDiaryMarkdown(body)),
}));
const hasTweetEmbed = diaryGroups.some((group) =>
  group.bodies.some((html) => html.includes('class="twitter-tweet"'))
);

const allEntries = await getCollection("diary");
const sortedAscending = [...allEntries].sort((a, b) =>
  a.data.yearMonth.localeCompare(b.data.yearMonth)
);
const sortedDescending = [...sortedAscending].reverse();

const currentIndex = sortedAscending.findIndex((item) => item.id === entry.id);
const prevEntry = currentIndex > 0 ? sortedAscending[currentIndex - 1] : null;
const nextEntry =
  currentIndex >= 0 && currentIndex < sortedAscending.length - 1
    ? sortedAscending[currentIndex + 1]
    : null;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="diary-page">
    <nav class="diary-nav diary-nav--desktop" aria-label="月別アーカイブ">
      <button
        type="button"
        class="diary-nav__scroll-btn diary-nav__scroll-btn--up"
        aria-label="上にスクロール"
      >
        ▲
      </button>
      <div class="diary-nav__scroll">
        <ul class="diary-nav__list">
          {
            sortedDescending.map((item) => (
              <li>
                <a
                  href={`/diary/${item.id}/`}
                  class="diary-nav__link"
                  aria-current={item.id === entry.id ? "page" : undefined}
                >
                  {formatYearMonthCompact(item.data.yearMonth)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <button
        type="button"
        class="diary-nav__scroll-btn diary-nav__scroll-btn--down"
        aria-label="下にスクロール"
      >
        ▼
      </button>
    </nav>

    <article class="diary-article">
      <div class="diary-header">
        {
          prevEntry && (
            <a
              class="diary-header__nav diary-header__nav--prev"
              href={`/diary/${prevEntry.id}/`}
            >
              ◀ {formatYearMonthCompact(prevEntry.data.yearMonth)}
            </a>
          )
        }
        <p class="diary-header__title">
          {formatYearMonthLong(entry.data.yearMonth)}
        </p>
        {
          nextEntry && (
            <a
              class="diary-header__nav diary-header__nav--next"
              href={`/diary/${nextEntry.id}/`}
            >
              {formatYearMonthCompact(nextEntry.data.yearMonth)} ▶
            </a>
          )
        }
      </div>

      <nav class="diary-nav diary-nav--mobile" aria-label="月別アーカイブ">
        <ul class="diary-nav__list">
          {
            sortedAscending.map((item) => (
              <li>
                <a
                  href={`/diary/${item.id}/`}
                  class="diary-nav__link"
                  aria-current={item.id === entry.id ? "page" : undefined}
                >
                  {formatYearMonthCompact(item.data.yearMonth)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="diary-article__body">
        {
          diaryGroups.map((group) => (
            <section class="diary-entry">
              <h2 class="diary-entry__heading">
                <span class="diary-entry__heading-text">{group.heading}</span>
                <span class="diary-entry__heading-rule" aria-hidden="true" />
              </h2>
              {group.bodies.map((html) => (
                <div class="diary-entry__post" set:html={html} />
              ))}
            </section>
          ))
        }
      </div>
    </article>
  </div>

  <div id="lightbox" class="lightbox">
    <img id="lightbox-img" class="lightbox__img" src="" alt="" />
  </div>

  {hasTweetEmbed && (
    <script
      async
      src="https://platform.twitter.com/widgets.js"
      charset="utf-8"
      data-astro-rerun
    />
  )}

  <style>
    .diary-page {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr min(720px, 100%) 1fr;
      column-gap: 40px;
      padding: 48px 24px 96px;
    }

    .diary-nav--desktop {
      grid-column: 1;
      justify-self: end;
      align-self: start;
      position: sticky;
      top: calc(var(--ncom-header-height) + 24px);
      display: flex;
      flex-direction: column;
      max-height: 200px;
    }

    .diary-nav__scroll {
      overflow-y: auto;
      scrollbar-width: none;
    }

    .diary-nav__scroll::-webkit-scrollbar {
      display: none;
    }

    .diary-nav__scroll-btn {
      display: block;
      width: 100%;
      flex-shrink: 0;
      border: none;
      background: none;
      color: var(--color-primary-dark);
      font-size: 12px;
      line-height: 1;
      padding: 4px 0;
      cursor: pointer;
      transition: opacity 0.15s ease;
    }

    .diary-nav__scroll-btn.is-faded {
      opacity: 0.3;
    }

    .diary-nav--mobile {
      display: none;
    }

    .diary-nav__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
    }

    .diary-nav__link {
      display: block;
      padding: 8px 12px;
      border-left: 2px solid transparent;
      color: var(--ncom-color-txt);
      font-family: var(--ncom-ff-roboto);
      font-size: 15px;
      text-decoration: none;
    }

    .diary-nav__link:hover {
      background-color: var(--ncom-bg-surface-100);
      opacity: 1;
    }

    .diary-nav__link[aria-current="page"] {
      border-left-color: var(--color-primary);
      color: var(--color-primary);
      font-weight: 700;
    }

    .diary-article {
      grid-column: 2;
      min-width: 0;
    }

    .diary-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: baseline;
      gap: 16px;
    }

    .diary-header__nav {
      color: var(--ncom-color-txt-sub);
      font-family: var(--ncom-ff-roboto);
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }

    .diary-header__nav:hover {
      color: var(--color-primary);
      opacity: 1;
    }

    .diary-header__nav--prev {
      grid-column: 1;
      justify-self: start;
    }

    .diary-header__nav--next {
      grid-column: 3;
      justify-self: end;
    }

    .diary-header__title {
      grid-column: 2;
      margin: 0;
      color: var(--ncom-color-heading);
      font-family: var(--ncom-ff-ja);
      font-size: 30px;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-align: center;
      white-space: nowrap;
    }

    .diary-article__body {
      margin-top: 27px;
      padding-top: 27px;
    }

    .diary-entry__heading {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 40px 0 16px;
      font-size: 0.85em;
    }

    .diary-entry:first-child .diary-entry__heading {
      margin-top: 0;
    }

    .diary-entry__heading-text {
      flex-shrink: 0;
      color: var(--color-text-faint);
    }

    .diary-entry__heading-rule {
      flex: 1 0 auto;
      align-self: center;
      height: 0;
      border-top: 2px solid var(--ncom-color-gray-300);
    }

    .diary-article__body :global(p) {
      margin: 0 0 0.4em;
    }

    .diary-article__body :global(p + p) {
      margin-top: 1.8em;
    }

    .diary-article__body :global(.diary-media) {
      display: block;
    }

    .diary-article__body :global(.diary-media--image),
    .diary-article__body :global(.diary-media--video) {
      width: 66.7%;
      max-width: 100%;
      height: auto;
      margin: 0 auto;
      border-radius: 12px;
      overflow: hidden;
    }

    .diary-article__body :global(.diary-media--image) {
      cursor: zoom-in;
    }

    .diary-article__body :global(.diary-media--video) {
      accent-color: var(--color-primary);
    }

    .diary-article__body :global(.diary-media--audio) {
      display: block;
      width: 75%;
      margin: 0 auto;
      accent-color: var(--color-primary);
    }

    .diary-article__body :global(.diary-image-pair) {
      display: flex;
      gap: 16px;
      margin: 0 0 16px;
    }

    .diary-article__body :global(.diary-image-pair .diary-media--image) {
      width: 48%;
      margin: 0;
    }

    .diary-article__body :global(.diary-embed-video) {
      width: 66.7%;
      max-width: 100%;
      margin: 1.5em auto;
      display: block;
    }

    .diary-article__body :global(.diary-embed-video iframe) {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 12px;
      border: none;
    }

    .diary-article__body :global(.diary-embed-tweet) {
      display: flex;
      justify-content: center;
      margin: 1.5em 0;
    }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 100;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.85);
      cursor: zoom-out;
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .lightbox.is-open {
      opacity: 1;
      transition: opacity 0.25s ease;
    }

    .lightbox__img {
      display: block;
      max-width: 90vw;
      max-height: 90vh;
      cursor: default;
      transform: scale(0.85);
      opacity: 0;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .lightbox.is-open .lightbox__img {
      transform: scale(1);
      opacity: 1;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    @media (max-width: 767px) {
      .diary-page {
        grid-template-columns: 1fr;
        padding: 32px 16px 64px;
      }

      .diary-nav--desktop {
        display: none;
      }

      .diary-nav--mobile {
        display: block;
        margin: 16px 0 24px;
      }

      .diary-nav--mobile .diary-nav__list {
        flex-direction: row;
        flex-wrap: nowrap;
        gap: 4px;
        overflow-x: auto;
        scrollbar-width: none;
      }

      .diary-nav--mobile .diary-nav__list::-webkit-scrollbar {
        display: none;
      }

      .diary-nav--mobile .diary-nav__link {
        flex-shrink: 0;
        white-space: nowrap;
        border-left: none;
        border-top: 2px solid transparent;
      }

      .diary-nav--mobile .diary-nav__link[aria-current="page"] {
        border-top-color: var(--color-primary);
      }

      .diary-article {
        grid-column: 1;
      }

      .diary-header__title {
        font-size: 22px;
      }

      .diary-header__nav {
        font-size: 13px;
      }

      .lightbox__img {
        margin-top: -8vh;
      }

      .diary-article__body :global(.diary-media--image),
      .diary-article__body :global(.diary-media--video),
      .diary-article__body :global(.diary-embed-video) {
        width: 83%;
      }

      .diary-article__body :global(.diary-image-pair) {
        width: 83%;
        flex-direction: row;
        justify-content: center;
      }

      .diary-article__body :global(.diary-image-pair .diary-media--image) {
        width: 48%;
      }
    }
  </style>

  <script>
    // View Transitions後は #lightbox / #lightbox-img が新しいDOMに差し替わるため、
    // 要素参照をモジュール読み込み時にキャッシュせず、使用のたびに取得し直す。
    // クリック検知もdocumentへのevent delegationに一本化し、遷移後も
    // スクリプトが再実行されなくても自然に機能するようにする。

    const LIGHTBOX_CLOSE_DURATION = 200; // .lightbox の閉じるtransitionと合わせる

    let lightboxIsOpen = false;
    let closeTimeoutId: number | undefined;

    function openLightbox(src: string, alt: string) {
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById(
        "lightbox-img"
      ) as HTMLImageElement | null;
      if (!lightbox || !lightboxImg) return;

      if (closeTimeoutId !== undefined) {
        window.clearTimeout(closeTimeoutId);
        closeTimeoutId = undefined;
      }
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.style.display = "flex";
      // display:none → flex にした直後に is-open を付けると
      // ブラウザがopen前の状態を描画せずtransitionが発火しないことがあるため、
      // 強制的にreflowさせてから is-open を付与する
      void lightbox.offsetHeight;
      lightbox.classList.add("is-open");
      lightboxIsOpen = true;
    }

    function closeLightbox() {
      if (!lightboxIsOpen) return;
      lightboxIsOpen = false;
      const lightbox = document.getElementById("lightbox");
      lightbox?.classList.remove("is-open");
      closeTimeoutId = window.setTimeout(() => {
        const lb = document.getElementById("lightbox");
        const lbImg = document.getElementById(
          "lightbox-img"
        ) as HTMLImageElement | null;
        if (lb) lb.style.display = "none";
        if (lbImg) lbImg.src = "";
        closeTimeoutId = undefined;
      }, LIGHTBOX_CLOSE_DURATION);
    }

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      const img = target.closest(".diary-media--image");
      if (img instanceof HTMLImageElement) {
        openLightbox(img.src, img.alt);
        return;
      }
      // オーバーレイ(画像以外)をクリックした場合のみ閉じる
      if (target.id === "lightbox") {
        closeLightbox();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && lightboxIsOpen) {
        closeLightbox();
      }
    });

    // モバイルの横スクロール月ナビで、現在の月が中央付近に見えるようにする
    // (PC表示では .diary-nav--mobile が display:none のため実質何もしない)
    document
      .querySelector<HTMLElement>('.diary-nav--mobile [aria-current="page"]')
      ?.scrollIntoView({ inline: "center", behavior: "smooth" });

    const NAV_SCROLL_STEP = 60;
    const desktopNavScroll = document.querySelector<HTMLElement>(
      ".diary-nav__scroll"
    );
    const navScrollUpBtn = document.querySelector<HTMLButtonElement>(
      ".diary-nav__scroll-btn--up"
    );
    const navScrollDownBtn = document.querySelector<HTMLButtonElement>(
      ".diary-nav__scroll-btn--down"
    );

    function updateNavScrollButtons() {
      if (!desktopNavScroll || !navScrollUpBtn || !navScrollDownBtn) return;
      const { scrollTop, scrollHeight, clientHeight } = desktopNavScroll;
      navScrollUpBtn.classList.toggle("is-faded", scrollTop <= 0);
      navScrollDownBtn.classList.toggle(
        "is-faded",
        scrollTop + clientHeight >= scrollHeight - 1
      );
    }

    if (desktopNavScroll && navScrollUpBtn && navScrollDownBtn) {
      updateNavScrollButtons();
      desktopNavScroll.addEventListener("scroll", updateNavScrollButtons);
      navScrollUpBtn.addEventListener("click", () => {
        desktopNavScroll.scrollBy({ top: -NAV_SCROLL_STEP, behavior: "smooth" });
      });
      navScrollDownBtn.addEventListener("click", () => {
        desktopNavScroll.scrollBy({ top: NAV_SCROLL_STEP, behavior: "smooth" });
      });
    }

    // View Transitions後、差し替え後のDOMに残った<video>/<audio>を
    // 確実に再ロードする(ソースが同じでも再生位置等の内部状態をリセットする)
    document.addEventListener("astro:page-load", () => {
      document.querySelectorAll("video, audio").forEach((el) => {
        (el as HTMLMediaElement).load();
      });
    });
  </script>
</BaseLayout>

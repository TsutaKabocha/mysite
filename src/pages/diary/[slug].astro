---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("diary");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allEntries = (await getCollection("diary")).sort((a, b) =>
  b.data.yearMonth.localeCompare(a.data.yearMonth)
);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="ncom-l-container diary-page">
    <aside class="diary-nav">
      <h2 class="diary-nav__heading">月別アーカイブ</h2>
      <ul class="diary-nav__list">
        {
          allEntries.map((item) => (
            <li>
              <a
                href={`/diary/${item.id}/`}
                class="diary-nav__link"
                aria-current={item.id === entry.id ? "page" : undefined}
              >
                {item.data.yearMonth.replace("-", ".")}
              </a>
            </li>
          ))
        }
      </ul>
    </aside>

    <article class="diary-article">
      <p class="diary-article__yearmonth">
        {entry.data.yearMonth.replace("-", ".")}
      </p>
      <h1>{entry.data.title}</h1>
      {
        entry.data.description && (
          <p class="diary-article__desc">{entry.data.description}</p>
        )
      }
      <div class="diary-article__body">
        <Content />
      </div>
    </article>
  </div>

  <style>
    .diary-page {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 48px;
      padding: 48px 24px 96px;
    }

    .diary-nav {
      position: sticky;
      top: calc(var(--ncom-header-height) + 24px);
      align-self: start;
    }

    .diary-nav__heading {
      margin-bottom: 16px;
      color: var(--ncom-color-txt-sub);
      font-size: 12px;
      letter-spacing: 0.03em;
    }

    .diary-nav__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
    }

    .diary-nav__link {
      display: block;
      padding: 10px 12px;
      border-left: 2px solid transparent;
      color: var(--ncom-color-txt);
      font-family: var(--ncom-ff-roboto);
      font-size: 16px;
      text-decoration: none;
    }

    .diary-nav__link:hover {
      background-color: var(--ncom-bg-surface-100);
      opacity: 1;
    }

    .diary-nav__link[aria-current="page"] {
      border-left-color: var(--ncom-color-red);
      color: var(--ncom-color-red);
      font-weight: 700;
    }

    .diary-article__yearmonth {
      margin: 0 0 8px;
      color: var(--ncom-color-txt-sub);
      font-family: var(--ncom-ff-roboto);
      font-size: 38px;
      line-height: 1;
    }

    .diary-article__desc {
      margin: 16px 0 0;
      color: var(--ncom-color-txt-sub);
    }

    .diary-article__body {
      margin-top: 40px;
      padding-top: 40px;
      border-top: 1px solid var(--ncom-color-gray-300);
    }

    .diary-article__body :global(h2) {
      margin-top: 40px;
      margin-bottom: 8px;
    }

    .diary-article__body :global(h2:first-child) {
      margin-top: 0;
    }

    .diary-article__body :global(p) {
      margin: 0 0 16px;
    }

    @media (max-width: 767px) {
      .diary-page {
        grid-template-columns: 1fr;
        padding: 32px 16px 64px;
      }

      .diary-nav {
        position: static;
      }

      .diary-nav__list {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 4px;
      }

      .diary-article__yearmonth {
        font-size: 28px;
      }
    }
  </style>
</BaseLayout>

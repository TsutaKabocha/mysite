---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  parseDiaryEntries,
  renderDiaryMarkdown,
  formatYearMonthCompact,
  formatYearMonthLong,
} from "../../lib/diary";

export async function getStaticPaths() {
  const entries = await getCollection("diary");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const diaryGroups = parseDiaryEntries(entry.body ?? "");

const allEntries = await getCollection("diary");
const sortedAscending = [...allEntries].sort((a, b) =>
  a.data.yearMonth.localeCompare(b.data.yearMonth)
);
const sortedDescending = [...sortedAscending].reverse();

const currentIndex = sortedAscending.findIndex((item) => item.id === entry.id);
const prevEntry = currentIndex > 0 ? sortedAscending[currentIndex - 1] : null;
const nextEntry =
  currentIndex >= 0 && currentIndex < sortedAscending.length - 1
    ? sortedAscending[currentIndex + 1]
    : null;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="diary-page">
    <nav class="diary-nav" aria-label="月別アーカイブ">
      <ul class="diary-nav__list">
        {
          sortedDescending.map((item) => (
            <li>
              <a
                href={`/diary/${item.id}/`}
                class="diary-nav__link"
                aria-current={item.id === entry.id ? "page" : undefined}
              >
                {formatYearMonthCompact(item.data.yearMonth)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <article class="diary-article">
      <div class="diary-header">
        {
          prevEntry && (
            <a
              class="diary-header__nav diary-header__nav--prev"
              href={`/diary/${prevEntry.id}/`}
            >
              ◀ {formatYearMonthCompact(prevEntry.data.yearMonth)}
            </a>
          )
        }
        <p class="diary-header__title">
          {formatYearMonthLong(entry.data.yearMonth)}
        </p>
        {
          nextEntry && (
            <a
              class="diary-header__nav diary-header__nav--next"
              href={`/diary/${nextEntry.id}/`}
            >
              {formatYearMonthCompact(nextEntry.data.yearMonth)} ▶
            </a>
          )
        }
      </div>

      <div class="diary-article__body">
        {
          diaryGroups.map((group) => (
            <section class="diary-entry">
              <h2 class="diary-entry__heading">
                <span class="diary-entry__heading-text">{group.heading}</span>
                <span class="diary-entry__heading-rule" aria-hidden="true" />
              </h2>
              {group.bodies.map((body) => (
                <div
                  class="diary-entry__post"
                  set:html={renderDiaryMarkdown(body)}
                />
              ))}
            </section>
          ))
        }
      </div>
    </article>
  </div>

  <div id="lightbox" class="lightbox" hidden>
    <img id="lightbox-img" class="lightbox__img" src="" alt="" />
  </div>

  <style>
    .diary-page {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr min(720px, 100%) 1fr;
      column-gap: 40px;
      padding: 48px 24px 96px;
    }

    .diary-nav {
      grid-column: 1;
      justify-self: end;
      align-self: start;
      position: sticky;
      top: calc(var(--ncom-header-height) + 24px);
    }

    .diary-nav__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
    }

    .diary-nav__link {
      display: block;
      padding: 8px 12px;
      border-left: 2px solid transparent;
      color: var(--ncom-color-txt);
      font-family: var(--ncom-ff-roboto);
      font-size: 15px;
      text-decoration: none;
    }

    .diary-nav__link:hover {
      background-color: var(--ncom-bg-surface-100);
      opacity: 1;
    }

    .diary-nav__link[aria-current="page"] {
      border-left-color: var(--color-primary);
      color: var(--color-primary);
      font-weight: 700;
    }

    .diary-article {
      grid-column: 2;
      min-width: 0;
    }

    .diary-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: baseline;
      gap: 16px;
    }

    .diary-header__nav {
      color: var(--ncom-color-txt-sub);
      font-family: var(--ncom-ff-roboto);
      font-size: 14px;
      text-decoration: none;
      white-space: nowrap;
    }

    .diary-header__nav:hover {
      color: var(--color-primary);
      opacity: 1;
    }

    .diary-header__nav--prev {
      grid-column: 1;
      justify-self: start;
    }

    .diary-header__nav--next {
      grid-column: 3;
      justify-self: end;
    }

    .diary-header__title {
      grid-column: 2;
      margin: 0;
      color: var(--ncom-color-heading);
      font-family: var(--ncom-ff-ja);
      font-size: 30px;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-align: center;
      white-space: nowrap;
    }

    .diary-article__body {
      margin-top: 40px;
      padding-top: 40px;
    }

    .diary-entry__heading {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 40px 0 8px;
      font-size: 0.85em;
    }

    .diary-entry:first-child .diary-entry__heading {
      margin-top: 0;
    }

    .diary-entry__heading-text {
      flex-shrink: 0;
      color: var(--color-text-faint);
    }

    .diary-entry__heading-rule {
      flex: 1 0 auto;
      align-self: center;
      height: 0;
      border-top: 2px solid var(--ncom-color-gray-300);
    }

    .diary-article__body :global(p) {
      margin: 0 0 16px;
    }

    .diary-article__body :global(.diary-media) {
      display: block;
    }

    .diary-article__body :global(.diary-media--image),
    .diary-article__body :global(.diary-media--video) {
      width: 66.7%;
      max-width: 100%;
      height: auto;
      margin: 0 auto;
      border-radius: 12px;
      overflow: hidden;
    }

    .diary-article__body :global(.diary-media--image) {
      cursor: zoom-in;
    }

    .diary-article__body :global(.diary-media--video) {
      accent-color: var(--color-primary);
    }

    .diary-article__body
      :global(.diary-media--video)::-webkit-media-controls-panel {
      background-color: var(--color-primary-pale);
    }

    .diary-article__body
      :global(
        .diary-media--video
      )::-webkit-media-controls-current-time-display,
    .diary-article__body
      :global(
        .diary-media--video
      )::-webkit-media-controls-time-remaining-display {
      color: var(--color-primary-deeper);
    }

    .diary-article__body
      :global(.diary-media--video)::-webkit-media-controls-play-button,
    .diary-article__body
      :global(.diary-media--video)::-webkit-media-controls-mute-button,
    .diary-article__body
      :global(.diary-media--video)::-webkit-media-controls-fullscreen-button {
      color: var(--color-primary-deeper);
    }

    .diary-article__body :global(.diary-media--audio) {
      width: 100%;
      accent-color: var(--color-primary);
    }

    .diary-article__body
      :global(.diary-media--audio)::-webkit-media-controls-panel {
      background-color: var(--color-primary-pale);
    }

    .diary-article__body
      :global(
        .diary-media--audio
      )::-webkit-media-controls-current-time-display,
    .diary-article__body
      :global(
        .diary-media--audio
      )::-webkit-media-controls-time-remaining-display {
      color: var(--color-primary-deeper);
    }

    .diary-article__body
      :global(.diary-media--audio)::-webkit-media-controls-play-button,
    .diary-article__body
      :global(.diary-media--audio)::-webkit-media-controls-mute-button {
      color: var(--color-primary-deeper);
    }

    .diary-article__body :global(.diary-image-pair) {
      display: flex;
      gap: 16px;
      margin: 0 0 16px;
    }

    .diary-article__body :global(.diary-image-pair .diary-media--image) {
      width: 48%;
      margin: 0;
    }

    .lightbox {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.85);
      cursor: zoom-out;
    }

    .lightbox[hidden] {
      display: none;
    }

    .lightbox__img {
      display: block;
      max-width: 90vw;
      max-height: 90vh;
      cursor: default;
    }

    @media (max-width: 767px) {
      .diary-page {
        grid-template-columns: 1fr;
        padding: 32px 16px 64px;
      }

      .diary-nav {
        grid-column: 1;
        justify-self: stretch;
        position: static;
        margin-bottom: 24px;
      }

      .diary-nav__list {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 4px;
      }

      .diary-nav__link {
        border-left: none;
        border-top: 2px solid transparent;
      }

      .diary-nav__link[aria-current="page"] {
        border-top-color: var(--color-primary);
      }

      .diary-article {
        grid-column: 1;
      }

      .diary-header__title {
        font-size: 22px;
      }

      .diary-header__nav {
        font-size: 13px;
      }
    }
  </style>

  <script>
    const lightbox = document.getElementById("lightbox") as HTMLElement;
    const lightboxImg = document.getElementById(
      "lightbox-img"
    ) as HTMLImageElement;

    function openLightbox(src: string, alt: string) {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.hidden = false;
    }

    function closeLightbox() {
      lightbox.hidden = true;
      lightboxImg.src = "";
    }

    document.addEventListener("click", (e) => {
      const target = e.target;
      if (
        target instanceof HTMLImageElement &&
        target.hasAttribute("data-lightbox")
      ) {
        openLightbox(target.src, target.alt);
        return;
      }
      // オーバーレイ(画像以外)をクリックした場合のみ閉じる
      if (target === lightbox) {
        closeLightbox();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.hidden) {
        closeLightbox();
      }
    });
  </script>
</BaseLayout>
